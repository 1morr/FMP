# OS and editor noise
.DS_Store
*.swp
~$*

# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code local settings only. Shared tasks/extensions can still be committed.
/.vscode/settings.json
/.vscode/launch.json

# Flutter / Dart / Pub state
/.dart_tool/
/.flutter-plugins
/.flutter-plugins-dependencies
/.pub-cache/
/.pub/
/build/
/coverage/
**/doc/api/

# pubspec.lock is tracked for this app to keep builds reproducible.

# Generated Dart sources
*.g.dart
*.freezed.dart
*.gr.dart
/lib/generated_plugin_registrant.dart

# Flutter symbolication / obfuscation output
app.*.symbols
app.*.map.json

# Android local build state and signing material
/android/.gradle/
/android/build/
/android/app/build/
/android/app/debug/
/android/app/profile/
/android/app/release/
/android/local.properties
/android/key.properties
/android/*.jks
/android/*.keystore

